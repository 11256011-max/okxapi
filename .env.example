# Copy this file to .env and fill in your own OKX credentials.
# Never commit .env. Never enable Withdraw permission for this bot.

OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# true = OKX demo/simulated trading header. Use demo API keys when this is true.
OKX_SIMULATED_TRADING=true

# true = never submit real orders. Keep this true until you verify the bot behavior.
DRY_RUN=true

# Extra guard for live orders. Real-money trading requires:
# DRY_RUN=false, OKX_SIMULATED_TRADING=false, ENABLE_LIVE_TRADING=true
ENABLE_LIVE_TRADING=false

# Single-market mode. In swap mode ETH/USDT is automatically normalized to ETH/USDT:USDT.
SYMBOL=ETH/USDT

# Multi-market mode. If this is set, it overrides SYMBOL. Aggressive mode runs ETH only.
SYMBOLS=ETH/USDT

ENTRY_TIMEFRAME=30m
CONFIRMATION_TIMEFRAMES=1h,4h
CANDLE_LIMIT=200
POLL_SECONDS=300

# USDT perpetual contracts only.
MARKET_TYPE=swap
MARGIN_MODE=isolated
# auto = detect OKX account mode before live/demo orders.
# net = one-way positions, hedge = long/short position mode.
POSITION_MODE=auto
# Gross risk is 8.5% so net loss after fees/slippage/funding stays near the 10% cap.
RISK_PER_TRADE_PCT=0.085
DAILY_MAX_LOSS_PCT=0.20
# Stop opening or adding positions after this many losing closes in one UTC day.
MAX_CONSECUTIVE_DAILY_LOSSES=2

# Combined strategy parameters. Legacy STRATEGY=ema_rsi or smc is mapped here.
STRATEGY=combined
SIGNAL_CONFIDENCE_THRESHOLD=0.68
LONG_CONFIDENCE_THRESHOLD=0.72
SHORT_CONFIDENCE_THRESHOLD=0.68
# Optional per-symbol confidence gates. BTC is stricter because recent backtests were weaker.
SYMBOL_CONFIDENCE_THRESHOLDS=ETH:0.68

# Layered SMC mode. 4H decides market state, 1H/4H confirm direction,
# and 30m decides entries with SMC as the main trigger.
LAYERED_SMC_ENABLED=true
LAYERED_MARKET_MA_PERIOD=50
LAYERED_MARKET_SLOPE_LOOKBACK=10
LAYERED_MARKET_MIN_TREND_PCT=0.003
LAYERED_MARKET_MIN_ATR_PCT=0.004
LAYERED_MARKET_MAX_RANGE_PCT=0.030
LAYERED_ENTRY_SMC_MIN_SCORE=0.50
LAYERED_ENTRY_REQUIRE_BOS=true
LAYERED_ENTRY_REQUIRE_PULLBACK=true
LAYERED_ENTRY_PULLBACK_TOLERANCE_PCT=0.003
LAYERED_ENTRY_MAX_CHASE_PCT=0.006
LAYERED_ENTRY_ORDER_FLOW_MIN_SCORE=0.20
LAYERED_ENTRY_POSITION_MIN_SCORE=0.50
# Only SMC is mandatory. Other modules are optional confirmations.
LAYERED_REQUIRE_LIQUIDITY_SWEEP=false

COMBINED_MIN_SCORE=0.68
COMBINED_MIN_EDGE=0.12
COMBINED_SWING_LOOKBACK=3
COMBINED_STRUCTURE_LOOKBACK=40
COMBINED_ORDER_FLOW_LOOKBACK=20
COMBINED_AVWAP_LOOKBACK=80
COMBINED_VOLUME_PROFILE_LOOKBACK=80
COMBINED_VOLUME_PROFILE_BINS=24
COMBINED_VALUE_AREA_PCT=0.70
COMBINED_SWEEP_TOLERANCE_PCT=0.001
COMBINED_MIN_DISPLACEMENT_PCT=0.002

# External context filter. Strategy signals are adjusted by news, GDELT tone,
# Crypto Fear & Greed, and optional manual fundamental bias.
EXTERNAL_CONTEXT_ENABLED=true
NEWSAPI_ENABLED=true
NEWSAPI_API_KEY=
NEWSAPI_PAGE_SIZE=20
GDELT_ENABLED=true
FEAR_GREED_ENABLED=true
FEAR_GREED_MODE=momentum
FUNDAMENTAL_CONTEXT_ENABLED=true
# Positive favors longs, negative favors shorts. Values can use -1..1 or -100..100.
# FUNDAMENTAL_BIAS=BTC:0.2,ETH:0.1,SOL:-0.1
EXTERNAL_CONTEXT_LOOKBACK_HOURS=24
# Fetch each external source at most once every 5 minutes per symbol.
EXTERNAL_CONTEXT_CACHE_SECONDS=300
EXTERNAL_CONTEXT_TIMEOUT_SECONDS=15
EXTERNAL_CONTEXT_MAX_CONFIDENCE_ADJUSTMENT=0.15
EXTERNAL_CONTEXT_MIN_SUPPORT=-0.35
EXTERNAL_CONTEXT_EXTREME_THRESHOLD=0.75
EXTERNAL_CONTEXT_RISK_MULTIPLIER=0.50

# Pyramiding / add-position rules. If these are not met, the bot keeps
# the existing position and does not add.
ADD_POSITION_ENABLED=true
MAX_POSITION_ADDS=2
ADD_POSITION_QUOTE_FRACTION=0.5
ADD_POSITION_REQUIRE_PROFIT=true
ADD_POSITION_MIN_PROFIT_PCT=0.15
ADD_POSITION_BREAKOUT_LOOKBACK=20
ADD_POSITION_PULLBACK_MA_PERIOD=20
ADD_POSITION_SUPPORT_LOOKBACK=20
ADD_POSITION_SUPPORT_TOLERANCE_PCT=0.003
ADD_POSITION_VOLUME_MULTIPLIER=1.2

# Risk controls, denominated in the quote currency, usually USDT.
ORDER_QUOTE_AMOUNT=20
MAX_QUOTE_PER_ORDER=20
STOP_LOSS_PCT=0.02
TAKE_PROFIT_PCT=0.04
# Optional per-symbol exits. ETH is optimized from the latest 365-day backtest.
SYMBOL_STOP_LOSS_PCTS=ETH:0.015
SYMBOL_TAKE_PROFIT_PCTS=ETH:0.06
ATTACH_TP_SL=true
SELL_FRACTION=1

# Dynamic exits use volatility, structure, and trend strength instead of a fixed TP only.
DYNAMIC_EXIT_ENABLED=true
# Empty means all symbols. Aggressive mode runs ETH only.
DYNAMIC_EXIT_SYMBOLS=ETH
DYNAMIC_EXIT_ATR_PERIOD=14
DYNAMIC_EXIT_STRUCTURE_LOOKBACK=20
DYNAMIC_EXIT_MIN_STOP_PCT=0.012
DYNAMIC_EXIT_MAX_STOP_PCT=0.030
DYNAMIC_EXIT_ATR_MULTIPLIER=1.2
DYNAMIC_EXIT_BASE_RR=2.0
DYNAMIC_EXIT_STRONG_RR=4.0
DYNAMIC_EXIT_STRONG_CONFIDENCE=0.70
DYNAMIC_EXIT_TREND_MA_PERIOD=20

# Aggressive exit simulation: later breakeven, no 3R partial take-profit,
# wider ATR trailing stop, and longer holds unless the dynamic stop is hit.
EXIT_BREAKEVEN_R=2.5
EXIT_PARTIAL_ENABLED=false
EXIT_PARTIAL_TAKE_PROFIT_R=3.0
EXIT_PARTIAL_FRACTION=0
EXIT_TRAILING_START_R=4.0
EXIT_TRAILING_ATR_MULTIPLIER=3.0
EXIT_TRAILING_ENABLED=true
EXIT_CLOSE_ON_OPPOSITE_SIGNAL=false

# Backtest-only cost assumptions. Fee and slippage are per side; funding is estimated per 8 hours.
BACKTEST_START_EQUITY=200
BACKTEST_FEE_PCT=0.0005
BACKTEST_SLIPPAGE_PCT=0.0005
BACKTEST_FUNDING_RATE_8H=0.0001

STATE_FILE=state.json
